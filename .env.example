# Server-side only — used by /api/analyze.js (Vercel serverless function).
# Do NOT prefix with VITE_, or it would be bundled into the client and exposed publicly.

# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — defaults to gemini-2.5-flash if unset.
GEMINI_MODEL=gemini-2.5-flash
